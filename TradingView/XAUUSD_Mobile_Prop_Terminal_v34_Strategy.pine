//@version=5
strategy("XAUUSD Mobile Prop Terminal v34 Strategy", overlay=true, initial_capital=10000, currency=currency.USD, pyramiding=0, process_orders_on_close=true, calc_on_order_fills=true, max_labels_count=100, max_lines_count=100, default_qty_type=strategy.fixed, default_qty_value=0.01, commission_type=strategy.commission.cash_per_contract, commission_value=0.0)

// -----------------------------------------------------------------------------
// XAUUSD / GOLD intraday strategy rebuilt from the mobile v34 terminal profile.
// Goal: clean TradingView backtest version with explicit entries, SL and TP exits.
// Use primarily on XAUUSD M15. Default quantity is 0.01 and capped manually at 0.04.
// -----------------------------------------------------------------------------

// Backtest and execution
qtyInput = input.float(0.01, "Backtest lot / qty", minval=0.01, maxval=0.04, step=0.01, group="Backtest")
useSessionFilter = input.bool(true, "London + NY only", group="Backtest")
londonSession = input.session("0800-1200", "London session", group="Backtest")
nySession = input.session("1300-1500", "NY session", group="Backtest")
cooldownBars = input.int(2, "Cooldown bars after signal", minval=0, maxval=20, group="Backtest")
tradeLong = input.bool(true, "Allow BUY", group="Backtest")
tradeShort = input.bool(true, "Allow SHORT", group="Backtest")

// Trend engine
fastEmaLen = input.int(20, "Signal EMA", minval=2, group="Trend")
midEmaLen = input.int(34, "Trend EMA", minval=2, group="Trend")
slowEmaLen = input.int(100, "Macro EMA", minval=10, group="Trend")
adxLen = input.int(14, "ADX length", minval=2, group="Trend")
adxSmooth = input.int(14, "ADX smoothing", minval=2, group="Trend")
minAdx = input.float(12.0, "Min ADX", minval=0.0, step=0.5, group="Trend")
maxAdx = input.float(70.0, "Max ADX", minval=10.0, step=0.5, group="Trend")

// Score gate
minScoreLondon = input.float(50.0, "Min score London", minval=0.0, maxval=100.0, step=1.0, group="Score")
minScoreNY = input.float(65.0, "Min score NY", minval=0.0, maxval=100.0, step=1.0, group="Score")
minScoreGap = input.float(8.0, "Min score gap", minval=0.0, maxval=50.0, step=1.0, group="Score")
blockWeakLondonBuyChase = input.bool(true, "Block weak London BUY chase", group="Score")

// Volatility and risk
atrLen = input.int(14, "ATR length", minval=1, group="Risk")
maxDistanceEmaAtr = input.float(3.20, "Max distance from signal EMA ATR", minval=0.2, step=0.1, group="Risk")
weakBuyMaxScore = input.float(55.0, "Weak BUY max score", minval=0.0, maxval=100.0, step=1.0, group="Risk")
weakBuyMinBodyAtr = input.float(0.30, "Weak BUY min body ATR", minval=0.0, step=0.05, group="Risk")
weakBuyMinDistAtr = input.float(2.20, "Weak BUY min distance ATR", minval=0.0, step=0.10, group="Risk")
slAtr = input.float(1.20, "SL ATR", minval=0.1, step=0.1, group="Risk")
tp1Atr = input.float(1.00, "TP1 ATR", minval=0.1, step=0.1, group="Risk")
tp2Atr = input.float(1.70, "TP2 ATR", minval=0.1, step=0.1, group="Risk")
finalAtr = input.float(2.40, "Final TP ATR", minval=0.1, step=0.1, group="Risk")
hardCutAtr = input.float(1.35, "Hard cut ATR", minval=0.1, step=0.1, group="Risk")

// Visuals
showEma = input.bool(false, "Show EMA/VWAP", group="Visual")
showTradeLines = input.bool(true, "Show Entry / SL / TP", group="Visual")
showLabels = input.bool(true, "Show BUY / SHORT labels", group="Visual")
showPanel = input.bool(true, "Show compact panel", group="Visual")

// Core calculations
emaFast = ta.ema(close, fastEmaLen)
emaMid = ta.ema(close, midEmaLen)
emaSlow = ta.ema(close, slowEmaLen)
vwapValue = ta.vwap(hlc3)
atr = ta.atr(atrLen)
bodyAtr = atr > 0.0 ? math.abs(close - open) / atr : 0.0
distEmaAtr = atr > 0.0 ? math.abs(close - emaFast) / atr : 0.0
slopeAtr = atr > 0.0 ? (emaFast - emaFast[1]) / atr : 0.0
[diPlus, diMinus, adx] = ta.dmi(adxLen, adxSmooth)

inLondon = not na(time(timeframe.period, londonSession))
inNY = not na(time(timeframe.period, nySession))
inSession = not useSessionFilter or inLondon or inNY
minScore = inLondon ? minScoreLondon : minScoreNY

// Scores: simple, readable and backtestable.
buyScore = 0.0
buyScore += close > emaFast ? 10.0 : 0.0
buyScore += emaFast > emaMid ? 10.0 : 0.0
buyScore += emaMid > emaSlow ? 10.0 : 0.0
buyScore += close > vwapValue ? 10.0 : 0.0
buyScore += slopeAtr > 0.05 ? 15.0 : 0.0
buyScore += diPlus > diMinus ? 10.0 : 0.0
buyScore += adx >= minAdx and adx <= maxAdx ? 15.0 : 0.0
buyScore += distEmaAtr <= maxDistanceEmaAtr ? 10.0 : 0.0
buyScore += close > open ? 10.0 : 0.0

sellScore = 0.0
sellScore += close < emaFast ? 10.0 : 0.0
sellScore += emaFast < emaMid ? 10.0 : 0.0
sellScore += emaMid < emaSlow ? 10.0 : 0.0
sellScore += close < vwapValue ? 10.0 : 0.0
sellScore += slopeAtr < -0.05 ? 15.0 : 0.0
sellScore += diMinus > diPlus ? 10.0 : 0.0
sellScore += adx >= minAdx and adx <= maxAdx ? 15.0 : 0.0
sellScore += distEmaAtr <= maxDistanceEmaAtr ? 10.0 : 0.0
sellScore += close < open ? 10.0 : 0.0

scoreGapBuy = buyScore - sellScore
scoreGapSell = sellScore - buyScore

weakLondonBuyChase = blockWeakLondonBuyChase and inLondon and buyScore <= weakBuyMaxScore and bodyAtr > weakBuyMinBodyAtr and distEmaAtr > weakBuyMinDistAtr
trendOk = adx >= minAdx and adx <= maxAdx
buyGate = tradeLong and inSession and trendOk and buyScore >= minScore and scoreGapBuy >= minScoreGap and slopeAtr > 0.05 and distEmaAtr <= maxDistanceEmaAtr and not weakLondonBuyChase
sellGate = tradeShort and inSession and trendOk and sellScore >= minScore and scoreGapSell >= minScoreGap and slopeAtr < -0.05 and distEmaAtr <= maxDistanceEmaAtr

var int lastSignalBar = na
cooldownOk = na(lastSignalBar) or bar_index - lastSignalBar >= cooldownBars
flat = strategy.position_size == 0
longSignal = barstate.isconfirmed and flat and cooldownOk and buyGate
shortSignal = barstate.isconfirmed and flat and cooldownOk and sellGate

var float tradeAtr = na
if longSignal
    tradeAtr := atr
    lastSignalBar := bar_index
    strategy.entry("BUY", strategy.long, qty=qtyInput, comment="BUY NOW")

if shortSignal
    tradeAtr := atr
    lastSignalBar := bar_index
    strategy.entry("SHORT", strategy.short, qty=qtyInput, comment="SHORT NOW")

if strategy.position_size == 0 and not longSignal and not shortSignal
    tradeAtr := na

activeAtr = na(tradeAtr) ? atr : tradeAtr
entry = strategy.position_avg_price
longSl = entry - activeAtr * slAtr
longHard = entry - activeAtr * hardCutAtr
longTp1 = entry + activeAtr * tp1Atr
longTp2 = entry + activeAtr * tp2Atr
longFinal = entry + activeAtr * finalAtr
shortSl = entry + activeAtr * slAtr
shortHard = entry + activeAtr * hardCutAtr
shortTp1 = entry - activeAtr * tp1Atr
shortTp2 = entry - activeAtr * tp2Atr
shortFinal = entry - activeAtr * finalAtr

if strategy.position_size > 0
    strategy.exit("BUY TP1", "BUY", qty_percent=40, stop=math.max(longSl, longHard), limit=longTp1, comment="TP1 / SL")
    strategy.exit("BUY TP2", "BUY", qty_percent=30, stop=math.max(longSl, longHard), limit=longTp2, comment="TP2 / SL")
    strategy.exit("BUY FINAL", "BUY", qty_percent=30, stop=math.max(longSl, longHard), limit=longFinal, comment="FINAL / SL")

if strategy.position_size < 0
    strategy.exit("SHORT TP1", "SHORT", qty_percent=40, stop=math.min(shortSl, shortHard), limit=shortTp1, comment="TP1 / SL")
    strategy.exit("SHORT TP2", "SHORT", qty_percent=30, stop=math.min(shortSl, shortHard), limit=shortTp2, comment="TP2 / SL")
    strategy.exit("SHORT FINAL", "SHORT", qty_percent=30, stop=math.min(shortSl, shortHard), limit=shortFinal, comment="FINAL / SL")

// Visual layer kept intentionally light for mobile.
plot(showEma ? emaFast : na, "Signal EMA", color=color.new(color.orange, 0))
plot(showEma ? emaMid : na, "Trend EMA", color=color.new(color.blue, 0))
plot(showEma ? emaSlow : na, "Macro EMA", color=color.new(color.gray, 0))
plot(showEma ? vwapValue : na, "VWAP", color=color.new(color.purple, 0))

longActive = strategy.position_size > 0
shortActive = strategy.position_size < 0
plot(showTradeLines and longActive ? entry : na, "BUY entry", color=color.new(color.green, 0), style=plot.style_linebr)
plot(showTradeLines and longActive ? longSl : na, "BUY SL", color=color.new(color.red, 0), style=plot.style_linebr)
plot(showTradeLines and longActive ? longTp1 : na, "BUY TP1", color=color.new(color.green, 30), style=plot.style_linebr)
plot(showTradeLines and longActive ? longTp2 : na, "BUY TP2", color=color.new(color.green, 20), style=plot.style_linebr)
plot(showTradeLines and longActive ? longFinal : na, "BUY Final", color=color.new(color.green, 0), style=plot.style_linebr)
plot(showTradeLines and shortActive ? entry : na, "SHORT entry", color=color.new(color.red, 0), style=plot.style_linebr)
plot(showTradeLines and shortActive ? shortSl : na, "SHORT SL", color=color.new(color.red, 0), style=plot.style_linebr)
plot(showTradeLines and shortActive ? shortTp1 : na, "SHORT TP1", color=color.new(color.red, 30), style=plot.style_linebr)
plot(showTradeLines and shortActive ? shortTp2 : na, "SHORT TP2", color=color.new(color.red, 20), style=plot.style_linebr)
plot(showTradeLines and shortActive ? shortFinal : na, "SHORT Final", color=color.new(color.red, 0), style=plot.style_linebr)

if showLabels and longSignal
    label.new(bar_index, low, "BUY NOW\nSL " + str.tostring(longSl, format.mintick) + "\nTP " + str.tostring(longFinal, format.mintick), style=label.style_label_up, textcolor=color.white, color=color.new(color.green, 0))

if showLabels and shortSignal
    label.new(bar_index, high, "SHORT NOW\nSL " + str.tostring(shortSl, format.mintick) + "\nTP " + str.tostring(shortFinal, format.mintick), style=label.style_label_down, textcolor=color.white, color=color.new(color.red, 0))

// Compact status panel.
var table panel = table.new(position.top_right, 2, 8, border_width=1)
status = longSignal ? "BUY NOW" : shortSignal ? "SHORT NOW" : weakLondonBuyChase ? "NO CHASE" : not inSession ? "WAIT" : "HOLD"
if showPanel and barstate.islast
    table.cell(panel, 0, 0, "v34", text_color=color.white, bgcolor=color.new(color.black, 0))
    table.cell(panel, 1, 0, status, text_color=color.white, bgcolor=longSignal ? color.new(color.green, 0) : shortSignal ? color.new(color.red, 0) : color.new(color.black, 0))
    table.cell(panel, 0, 1, "BUY", text_color=color.white)
    table.cell(panel, 1, 1, str.tostring(buyScore, "#.0"), text_color=color.white)
    table.cell(panel, 0, 2, "SELL", text_color=color.white)
    table.cell(panel, 1, 2, str.tostring(sellScore, "#.0"), text_color=color.white)
    table.cell(panel, 0, 3, "ADX", text_color=color.white)
    table.cell(panel, 1, 3, str.tostring(adx, "#.0"), text_color=color.white)
    table.cell(panel, 0, 4, "Dist", text_color=color.white)
    table.cell(panel, 1, 4, str.tostring(distEmaAtr, "#.00"), text_color=color.white)
    table.cell(panel, 0, 5, "ATR", text_color=color.white)
    table.cell(panel, 1, 5, str.tostring(atr, "#.00"), text_color=color.white)
    table.cell(panel, 0, 6, "Session", text_color=color.white)
    table.cell(panel, 1, 6, inLondon ? "London" : inNY ? "NY" : "Off", text_color=color.white)
    table.cell(panel, 0, 7, "Qty", text_color=color.white)
    table.cell(panel, 1, 7, str.tostring(qtyInput, "#.00"), text_color=color.white)

alertcondition(longSignal, title="BUY NOW", message="XAUUSD v34 strategy BUY NOW | Entry={{close}}")
alertcondition(shortSignal, title="SHORT NOW", message="XAUUSD v34 strategy SHORT NOW | Entry={{close}}")
alertcondition(weakLondonBuyChase, title="NO CHASE", message="XAUUSD v34 strategy blocks weak London BUY chase")
